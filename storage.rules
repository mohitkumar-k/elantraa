rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'admin@elantraa.com';
    }

    match /products/{productId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categorySlug}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /site-content/{page}/{section}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
